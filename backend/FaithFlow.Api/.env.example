# Production / App Runner environment variables (reference only — do not commit secrets)
ASPNETCORE_ENVIRONMENT=Production
Database__Provider=Postgres
ConnectionStrings__DefaultConnection=Host=YOUR_RDS_HOST;Port=5432;Database=faithflow;Username=faithflow;Password=YOUR_PASSWORD;SSL Mode=Require;Trust Server Certificate=true
Cognito__Authority=https://cognito-idp.us-east-1.amazonaws.com/us-east-1_YOUR_POOL
Cognito__UserPoolId=us-east-1_YOUR_POOL
Cognito__ClientId=YOUR_CLIENT_ID
Cognito__Region=us-east-1
Cors__AllowedOrigins__0=https://main.xxxxx.amplifyapp.com
